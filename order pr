import java.util.Scanner;

interface Order {
    void placeOrder(String item, int qty);
    void cancelOrder(int orderId);
    void generateBill();
}

abstract class PartialOrder implements Order {
    String item;
    int qty;
    int orderId = 101;

    public void placeOrder(String item, int qty) {
        this.item = item;
        this.qty = qty;
        System.out.println("Order Placed: " + item + " x " + qty);
    }
}

class FinalOrder extends PartialOrder {

    public void cancelOrder(int orderId) {
        if (this.orderId == orderId)
            System.out.println("Order Cancelled");
        else
            System.out.println("Invalid Order ID");
    }

    public void generateBill() {
        int price = 100;
        int total = qty * price;
        System.out.println("Bill Amount = " + total);
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        FinalOrder fo = new FinalOrder();

        String item = sc.next();
        int qty = sc.nextInt();

        fo.placeOrder(item, qty);

        int choice = sc.nextInt();

        if (choice == 1) {
            fo.generateBill();
        } else if (choice == 2) {
            int id = sc.nextInt();
            fo.cancelOrder(id);
        }
    }
}
