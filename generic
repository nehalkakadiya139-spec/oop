import java.util.*;
class Box<T>{
    ArrayList<T> l=new ArrayList<>();
    void addItem(T i){l.add(i);}
    void show(){System.out.println(l);}
}
public class Main{
    public static void main(String[] args){
        Box<String> a=new Box<>();
        Box<Integer> b=new Box<>();
        a.addItem("A"); b.addItem(1);
        a.show(); b.show();
    }
}
